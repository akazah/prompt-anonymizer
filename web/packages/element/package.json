{
  "name": "@prompt-anonymizer/element",
  "version": "0.3.3",
  "description": "A buddy check for PII before it reaches an LLM - consistent, reversible labels. Framework-agnostic <prompt-anonymizer> web component built on @prompt-anonymizer/core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akazah/prompt-anonymizer.git",
    "directory": "web/packages/element"
  },
  "homepage": "https://github.com/akazah/prompt-anonymizer#readme",
  "bugs": {
    "url": "https://github.com/akazah/prompt-anonymizer/issues"
  },
  "keywords": [
    "pii",
    "anonymization",
    "privacy",
    "llm",
    "web-component",
    "custom-element"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prompt-anonymizer/core": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^28.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
