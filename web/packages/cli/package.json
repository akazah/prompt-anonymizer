{
  "name": "@prompt-anonymizer/cli",
  "version": "0.3.0",
  "description": "Anonymize PII before it reaches an LLM - consistent, reversible labels. Node CLI (npx prompt-anonymizer) built on @prompt-anonymizer/core.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "prompt-anonymizer": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akazah/prompt-anonymizer.git",
    "directory": "web/packages/cli"
  },
  "homepage": "https://github.com/akazah/prompt-anonymizer#readme",
  "bugs": {
    "url": "https://github.com/akazah/prompt-anonymizer/issues"
  },
  "keywords": [
    "pii",
    "anonymization",
    "privacy",
    "llm",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prompt-anonymizer/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
