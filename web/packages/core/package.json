{
  "name": "@prompt-anonymizer/core",
  "version": "0.3.0",
  "description": "Anonymize PII before it reaches an LLM - consistent, reversible labels. Browser-first core (regex recognizers + transformers.js NER).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./languages": {
      "types": "./dist/languages.d.ts",
      "import": "./dist/languages.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akazah/prompt-anonymizer.git",
    "directory": "web/packages/core"
  },
  "homepage": "https://github.com/akazah/prompt-anonymizer#readme",
  "bugs": {
    "url": "https://github.com/akazah/prompt-anonymizer/issues"
  },
  "keywords": [
    "pii",
    "anonymization",
    "privacy",
    "llm",
    "presidio",
    "ner"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "ibantools": "^4.5.4"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
