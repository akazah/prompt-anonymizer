{
  "name": "@prompt-anonymizer/react",
  "version": "0.2.0",
  "description": "Anonymize PII before it reaches an LLM - consistent, reversible labels. React hooks for @prompt-anonymizer/core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akazah/prompt-anonymizer.git",
    "directory": "web/packages/react"
  },
  "keywords": [
    "pii",
    "anonymization",
    "privacy",
    "llm",
    "react",
    "hooks"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prompt-anonymizer/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@types/react": "^19.2.0",
    "@testing-library/react": "^16.3.0",
    "jsdom": "^28.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
