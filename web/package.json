{
  "name": "prompt-anonymizer-web",
  "private": true,
  "version": "0.3.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm --filter \"./packages/*\" build && pnpm -r test",
    "e2e": "pnpm --filter @prompt-anonymizer/e2e e2e",
    "e2e:ner": "pnpm --filter @prompt-anonymizer/e2e e2e:ner",
    "docs:links": "node scripts/check-docs-links.mjs",
    "docs:freshness": "node scripts/check-docs-freshness.mjs",
    "docs:check": "node scripts/check-docs-links.mjs && node scripts/check-docs-freshness.mjs",
    "lint": "pnpm --filter \"./packages/*\" build && pnpm -r lint"
  },
  "devDependencies": {
    "github-slugger": "^2.0.0",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.10.0"
}
